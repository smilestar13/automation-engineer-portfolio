[
  {
    "type": "newPage",
    "config": {}
  },
  {
    "type": "useExcel",
    "config": {
      "path": "C:\\Users\\example-path\\registration-data.xlsx",
      "variableList": [
        "serial_number",
        "user_name",
        "user_email",
        "account_name",
        "account_identifier",
        "extension_password",
        "authorization_key",
        "proxy_ip"
      ],
      "isSkip": "0",
      "remark": "Load registration data from spreadsheet"
    }
  },
  {
    "type": "gotoUrl",
    "config": {
      "url": "chrome-extension://<extension-id>/home.html",
      "timeout": 3000,
      "remark": "Open browser extension"
    }
  },
  {
    "type": "waitForSelector",
    "config": {
      "selectorRadio": "CSS",
      "selector": "[type=\"password\"]",
      "serial": 1,
      "isShow": "1",
      "timeout": 30000,
      "variable": "",
      "remark": "Wait for extension password field"
    }
  },
  {
    "type": "getActiveElement",
    "config": {
      "variable": "active_element",
      "remark": "Get active password input"
    }
  },
  {
    "type": "inputContent",
    "config": {
      "selectorRadio": "CSS",
      "selector": "",
      "serialType": "fixedValue",
      "selectorType": "element",
      "element": "active_element",
      "serial": 1,
      "serialMin": 1,
      "serialMax": 50,
      "intervals": 30,
      "content": "",
      "isRandom": "0",
      "randomContent": "${extension_password}",
      "randomInputNum": {
        "min": 0.1,
        "max": 10
      },
      "remark": "Input extension password"
    }
  },
  {
    "type": "keyboard",
    "config": {
      "type": "Enter",
      "remark": "Submit extension password"
    }
  },
  {
    "type": "waitTime",
    "config": {
      "timeoutType": "fixedValue",
      "timeout": 3000,
      "timeoutMin": 1000,
      "timeoutMax": 300000,
      "remark": "Wait for extension unlock"
    }
  },
  {
    "type": "closePage",
    "config": {}
